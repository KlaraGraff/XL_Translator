{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Translator",
  "version": "8.0.0",
  "identifier": "com.klara-graff.translator",
  "build": {
    "beforeDevCommand": "cd ui && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd ui && npm run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Translator",
        "width": 1380,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../assets/branding/app-icon-original.png"]
  }
}
