{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XL Translator",
  "version": "5.0.1",
  "identifier": "com.klara-graff.xl-translator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist-tauri"
  },
  "app": {
    "windows": [
      {
        "title": "XL Translator",
        "width": 1320,
        "height": 880,
        "minWidth": 1040,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": {
      "resources/workers": "workers"
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "hardenedRuntime": false
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    }
  }
}
